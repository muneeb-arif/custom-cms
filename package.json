{
  "name": "cms",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 9000",
    "build": "npm run db:generate && npm run db:push && next build",
    "start": "next start -p 9000",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:baseline": "prisma db execute --file ./prisma/migrations/20250316000000_add_custom_types/migration.sql && prisma migrate resolve --applied \"20250316000000_add_custom_types\" && prisma migrate resolve --applied \"20260309212248_add_page_banner_fields\" && prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.19.0",
    "@vercel/blob": "^2.3.1",
    "autoprefixer": "^10.4.17",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "next": "latest",
    "next-auth": "beta",
    "postcss": "^8.4.35",
    "react": "latest",
    "react-dom": "latest",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^3.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "prisma": "5.19.0",
    "typescript": "latest"
  }
}
